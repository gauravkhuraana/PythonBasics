# ============================================================
# Configuration for "Getting Started with Python + AI"
# ============================================================
# INSTRUCTIONS:
# 1. Copy this file and rename it to: .env
# 2. Fill in the values you need (local-only is enough for V1-V9)
# 3. NEVER commit .env to git (it contains secrets!)
# ============================================================

# ------------------------------------------------------------
# Local LLM (LM Studio) — used in Videos 6, 7, 8, 9
# ------------------------------------------------------------
# Start LM Studio → load a model → click "Start Server" in the
# "Local Server" / Developer tab. Copy the URL and model id below.

# OpenAI-compatible URL exposed by LM Studio (default port 1234)
LOCAL_LLM_BASE_URL=http://localhost:1234/v1

# The model identifier shown at the top of LM Studio's server tab
# Examples (any small instruct model works):
#   lmstudio-community/Llama-3.2-3B-Instruct-GGUF
#   lmstudio-community/Qwen2.5-3B-Instruct-GGUF
#   lmstudio-community/Phi-4-mini-instruct-GGUF
#   lmstudio-community/gemma-3-4b-it-GGUF
LOCAL_LLM_MODEL=local-model


# ------------------------------------------------------------
# OpenRouter — optional, used in Video 8
# ------------------------------------------------------------
# Skip this unless you want to try hosted models alongside LM Studio.
# Get a free key at: https://openrouter.ai → Keys

OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini
